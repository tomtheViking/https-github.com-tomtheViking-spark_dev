{
  "entities": {
    "CallSession": {
      "title": "CallSession",
      "description": "Represents an analyzed sales call session with conversational diagnostics.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique call session ID."
        },
        "title": {
          "type": "string",
          "description": "Descriptive title of the call."
        },
        "customerName": {
          "type": "string",
          "description": "The customer's full name."
        },
        "repName": {
          "type": "string",
          "description": "The representative's full name."
        },
        "date": {
          "type": "string",
          "description": "The date and time of the call."
        },
        "transcriptText": {
          "type": "string",
          "description": "The raw word-for-word conversational transcript text."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "analyzed", "failed"],
          "description": "Processing status of the transcript analytics."
        },
        "tenantId": {
          "type": "string",
          "description": "The simulated multi-tenant ID."
        }
      },
      "required": ["id", "title", "customerName", "repName", "date", "status"]
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "description": "Represents an inbound support ticket created by enterprise customer portals.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique ticket ID."
        },
        "title": {
          "type": "string",
          "description": "The subject/title of the inquiry."
        },
        "tenantId": {
          "type": "string",
          "description": "The tenant ID."
        },
        "tenantName": {
          "type": "string",
          "description": "The name of the tenant."
        },
        "priority": {
          "type": "string",
          "enum": ["HIGH", "MEDIUM", "LOW"],
          "description": "Severity level of the ticket."
        },
        "status": {
          "type": "string",
          "enum": ["Open", "In Progress", "Resolved"],
          "description": "Resolution status."
        },
        "customerMessage": {
          "type": "string",
          "description": "Detailed text body describing the complaint or problem."
        },
        "createdAt": {
          "type": "string",
          "description": "ISO timestamp when the ticket was generated."
        }
      },
      "required": ["id", "title", "tenantId", "tenantName", "priority", "status", "customerMessage", "createdAt"]
    },
    "BillingDetails": {
      "title": "BillingDetails",
      "description": "Represents secure payment details, credit card and billing contacts for multi-tenant subscription isolation.",
      "type": "object",
      "properties": {
        "contactName": {
          "type": "string",
          "description": "The billing contact person's full name."
        },
        "email": {
          "type": "string",
          "description": "Billing communication email."
        },
        "phone": {
          "type": "string",
          "description": "Billing contact telephone number."
        },
        "address": {
          "type": "string",
          "description": "Street address of the paying entity."
        },
        "city": {
          "type": "string",
          "description": "City of the paying entity."
        },
        "state": {
          "type": "string",
          "description": "State code or province name."
        },
        "zipCode": {
          "type": "string",
          "description": "Postal or Zip Code."
        },
        "cardNumber": {
          "type": "string",
          "description": "Masked credit card number (e.g. **** **** **** 4111) or mock payment digit inputs."
        },
        "cardExpiry": {
          "type": "string",
          "description": "Credit card expiration date (MM/YY)."
        },
        "cardCvv": {
          "type": "string",
          "description": "Security CVV/CVC code (3 or 4 digits)."
        }
      },
      "required": ["contactName", "email", "phone", "address", "city", "state", "zipCode", "cardNumber", "cardExpiry", "cardCvv"]
    },
    "UserInvitation": {
      "title": "UserInvitation",
      "description": "Represents an invitation sent to a new customer user.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "The email address of the invited user."
        },
        "tenant_id": {
          "type": "string",
          "description": "The unique tenant identifier."
        },
        "role": {
          "type": "string",
          "description": "The role assigned to the user (e.g. tenant_admin)."
        },
        "enrollment_status": {
          "type": "string",
          "enum": ["invited", "active"],
          "description": "The enrollment status of the user."
        },
        "created_at": {
          "type": "string",
          "description": "ISO timestamp when the invitation was created."
        }
      },
      "required": ["email", "tenant_id", "role", "enrollment_status", "created_at"]
    },
    "CustomerTenant": {
      "title": "CustomerTenant",
      "description": "Represents an isolated customer tenant profile.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "companyName": { "type": "string" },
        "address1": { "type": "string" },
        "address2": { "type": "string" },
        "email": { "type": "string" },
        "secondEmail": { "type": "string" },
        "phone": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "zipCode": { "type": "string" },
        "subdomain": { "type": "string" },
        "customerPortalAssigned": { "type": "boolean" },
        "performancePortalAssigned": { "type": "boolean" },
        "activationToken": { "type": "string" },
        "tempPassword": { "type": "string" },
        "activationStatus": { "type": "string", "enum": ["Not Invited", "Invited", "Active"] }
      },
      "required": ["id", "companyName", "email", "subdomain"]
    },
    "TranscriptRecord": {
      "title": "TranscriptRecord",
      "description": "Represents a multi-party dialogue transcript record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "customerName": { "type": "string" },
        "userName": { "type": "string" },
        "date": { "type": "string" },
        "fileName": { "type": "string" },
        "duration": { "type": "string" },
        "fullText": { "type": "string" }
      },
      "required": ["id", "tenantId", "fileName", "fullText"]
    },
    "TelemetryAlert": {
      "title": "TelemetryAlert",
      "description": "Telemetry alerts for service components.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string" },
        "tenantId": { "type": "string" },
        "serviceComponent": { "type": "string" },
        "awsErrorCode": { "type": "string" },
        "diagnosticMessage": { "type": "string" },
        "severity": { "type": "string", "enum": ["critical", "warning", "info"] }
      },
      "required": ["id", "timestamp", "tenantId", "serviceComponent", "awsErrorCode", "diagnosticMessage", "severity"]
    }
  },
  "firestore": {
    "/sessions/{sessionId}": {
      "schema": "CallSession",
      "description": "Root collection for all simulated sales call dialogue sessions."
    },
    "/tenants/{tenantId}/sessions/{sessionId}": {
      "schema": "CallSession",
      "description": "Multi-tenant partitioned sales dialogue session collection."
    },
    "/tickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "Global support tickets synced between customer facing portals and help desks."
    },
    "/tenants/{tenantId}/billing/details": {
      "schema": "BillingDetails",
      "description": "Subscription billing contacts and credit/debit payment details partition."
    },
    "/users/{userId}": {
      "schema": "UserInvitation",
      "description": "User invitations and profile details collection."
    },
    "/tenants/{tenantId}": {
      "schema": "CustomerTenant",
      "description": "Customer tenant configuration and profile details."
    },
    "/transcripts/{transcriptId}": {
      "schema": "TranscriptRecord",
      "description": "Offline compliance transcripts for batch dialogue search."
    },
    "/alerts/{alertId}": {
      "schema": "TelemetryAlert",
      "description": "System telemetry and AWS service error logs collection."
    }
  }
}
