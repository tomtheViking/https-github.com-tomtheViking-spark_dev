files:
  "/tmp/setup_swap.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      SWAPFILE=/var/swapfile
      SWAP_SIZE_MB=2048

      if grep -q "$SWAPFILE" /proc/swaps; then
        echo "Swap file $SWAPFILE is already active."
        exit 0
      fi

      if [ -f "$SWAPFILE" ]; then
        echo "Swap file $SWAPFILE exists but is not active. Activating..."
        swapon $SWAPFILE
        exit 0
      fi

      echo "Creating $SWAP_SIZE_MB MB swap file at $SWAPFILE..."
      fallocate -l ${SWAP_SIZE_MB}M $SWAPFILE || dd if=/dev/zero of=$SWAPFILE bs=1M count=$SWAP_SIZE_MB

      chmod 600 $SWAPFILE
      mkswap $SWAPFILE
      swapon $SWAPFILE

      if ! grep -q "$SWAPFILE" /etc/fstab; then
        echo "$SWAPFILE swap swap defaults 0 0" >> /etc/fstab
        echo "Added swap to /etc/fstab"
      fi

      echo "Swap setup completed successfully!"

commands:
  01_run_swap_setup:
    command: "/tmp/setup_swap.sh"
